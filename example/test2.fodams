qualityAttributes {
    quality Performance;
    quality Scalability;
    quality HighEnergyConsumption;
}

featureTree QualityAttributes {
    optional Performance;
    optional Scalability;
    optional HighEnergyConsumption;
};

constraints {
}

tradeOffs {
    Performance increases Scalability;
    Scalability increases HighEnergyConsumption;
    HighEnergyConsumption reduces Performance;
    
}

configuration {
    priorityGroup { 
        Performance;
    }
    priorityGroup { 
        HighEnergyConsumption;
    }
    priorityGroup { Scalability; }
}